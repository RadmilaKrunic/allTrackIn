# Copy this file to .env and fill in your values
# .env is git-ignored and must never be committed

PORT=3001
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Path where NeDB .db files are stored
# Railway: set this to the mounted volume path, e.g. /app/data
# Local:   leave unset — defaults to backend/data/
# DATA_PATH=/app/data
