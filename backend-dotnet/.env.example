# MongoDB connection
MongoDB__ConnectionString=mongodb://localhost:27017
MongoDB__DatabaseName=allTrackin

# JWT
Jwt__Secret=change-this-to-a-long-random-string-in-production-at-least-32-chars
Jwt__ExpiryDays=30

# CORS - comma-separated list or * for all origins
AllowedOrigins=*

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:5000
